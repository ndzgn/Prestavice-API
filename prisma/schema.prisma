// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  ARTISAN
}

model Users {
  id              String          @id @default(uuid())
  email           String          @unique @db.VarChar(100)
  username        String          @db.VarChar(100)
  password        String
  picture         String?
  role            UserRole        @default(USER)
  isEmailVerified Boolean         @default(false)
  review          Review[]
  isActive        Boolean         @default(true)
  artisan         Artisans? //user in one to one relationship with artisan
  offers          Offers[] // a user can create many missions
  notifications   Notifications[]
  transactions    Transactions[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Artisans {
  id         String      @id @default(uuid())
  user       Users       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: Cascade) // artisan in one to one relationship with user
  userId     String      @unique
  name       String      @db.VarChar(100)
  email      String      @unique @db.VarChar(100)
  phone      String      @unique @db.Char(20)
  town       String      @db.VarChar(50)
  district   String      @db.VarChar(50)
  service    String      @db.VarChar(100)
  picture    String?
  missions   Offers[]
  devis      Quotation[]
  review     Review[]
  mark       Decimal?
  isActive   Boolean     @default(true)
  isVerified Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum OfferStatus {
  PENDING
  ACCEPTED
  INPROGRESS
  CANCELLED
  COMPLETED
  FAILED
}

model Offers {
  id          String      @id @default(uuid())
  author      Users?      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId      String?
  town        String      @db.VarChar(100)
  district    String      @db.VarChar(100)
  phone       String      @db.Char(9)
  title       String      @db.VarChar(100)
  description String      @db.VarChar(500)
  service     String      @db.VarChar(100)
  status      OfferStatus @default(PENDING)
  quotation   Quotation[]
  artisans    Artisans?   @relation(fields: [artisansId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  artisansId  String?
  review      Review?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum DevisStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model Quotation {
  id          String      @id @default(uuid())
  artisan     Artisans?   @relation(fields: [artisanId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  artisanId   String?
  mission     Offers?     @relation(fields: [offerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  offerId     String?
  description String      @db.VarChar(2000)
  tools       Tools[]
  amount      Decimal     @db.Decimal(10, 2)
  status      DevisStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Tools {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  quantity    Int?
  price       Decimal?   @db.Decimal(10, 2)
  total       Decimal?   @db.Decimal(10, 2)
  quotation   Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  quotationId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Review {
  id        Int       @id @default(autoincrement())
  user      Users?    @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  userId    String?
  artisan   Artisans? @relation(fields: [artisanId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  artisanId String?
  offers    Offers    @relation(fields: [offerId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  offerId   String    @unique
  content   String    @db.VarChar(100)
  mark      Int       @db.SmallInt
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum NotificationType {
  INAPP
  EMAIL
  WHATSAPP
  SMS
}

model Notifications {
  id           String           @id @default(uuid())
  user         Users?           @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  userId       String?
  content      String           @db.VarChar(255)
  resourceLink String
  type         NotificationType
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transactions {
  id          String            @id @default(uuid())
  users       Users?            @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  userId      String?
  amount      Decimal           @db.Money
  description String            @db.VarChar(255)
  type        TransactionType
  status      TransactionStatus
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}
